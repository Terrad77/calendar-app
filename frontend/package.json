    "@stitches/react": "^1.2.8",
    "@types/lodash.debounce": "^4.0.9",
    "axios": "^1.12.2",
    "calendar-app": "file:..",
    "dayjs": "^1.11.18",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.0",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.6",
    "normalize.css": "^8.0.1",
    "openai": "^5.12.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.66.1",
