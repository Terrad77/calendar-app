{
  "name": "calendar-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare": "node -e \"if (require('fs').existsSync('.git')) { require('child_process').execSync('npx husky install', { stdio: 'inherit' }) } else { console.log('Skipping husky') }\"",
    "dev": "cross-env FORCE_COLOR=1 vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
