{
  "name": "calendar-backend",
  "version": "1.0.0",
  "description": "Backend service for calendar holidays",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "start": "node -r dotenv/config --enable-source-maps dist/src/server.js",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc --build --force",
    "db:migrate": "drizzle-kit migrate",
    "build:es": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && npx esbuild src/server.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/src/server.js --external:*/** --sourcemap",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "auto-start": "npm run build && npm start"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^7.58.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "axios": "^1.7.2",
    "bcrypt": "^6.0.0",
    "calendar-app": "file:..",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "json-schema-typed": "^8.0.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "postgres": "^3.4.9",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
