## Backend environment variables example
# Copy this file to backend/.env and fill values. Do NOT commit real secrets.

# Application
PORT=3001

# Local development defaults
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# In Render production set:
# BACKEND_URL=https://calendar-app-i6oa.onrender.com
# FRONTEND_URL=https://calendar-app-pi-gold.vercel.app

# Database
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# JWT secrets
JWT_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Google AI / Gemini
GOOGLE_AI_API_KEY=

# SMTP (for account emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Sentry configuration
SENTRY_DSN=
SENTRY_RELEASE=calendar-backend@dev
SENTRY_TRACES_SAMPLE_RATE=0.1
